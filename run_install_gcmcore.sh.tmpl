#!/usr/bin/env bash
# code: language=bash

function __install_linux() {
  GCM_CORE_VERSION="2.0.877"
  SOURCE_URL="https://github.com/GitCredentialManager/git-credential-manager/releases/download/v$GCM_CORE_VERSION/gcm-linux_amd64.$GCM_CORE_VERSION.tar.gz"

  gcm_installed_version=$(git-credential-manager --version 2>/dev/null | grep -oP '(\d+\.)+\d+')

  if [ "$gcm_installed_version" != "$GCM_CORE_VERSION" ]; then
    cd /tmp
    wget $SOURCE_URL
    sudo tar -xvzf gcm-linux_amd64.$GCM_CORE_VERSION.tar.gz -C /usr/local/bin git-credential-manager
  fi

}

function __install_mac() {
  HOMEBREW_NO_AUTO_UPDATE=1
  brew list -q1 git-credential-manager-core > /dev/null || brew install --cask microsoft/git/git-credential-manager-core
}

{{ if eq .chezmoi.os "darwin" -}}
__install_mac
{{ else if eq .chezmoi.os "linux" -}}
__install_linux
{{ end -}}

git-credential-manager configure
