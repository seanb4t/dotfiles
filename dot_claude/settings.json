{
  "skillListingBudgetFraction": 0.015,
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(astgrep *)",
      "Bash(awk *)",
      "Bash(dig *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(if *)",
      "Bash(jq *)",
      "Bash(kubectl *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(pre-commit *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(terraform plan *)",
      "Bash(test *)",
      "Bash(vault kv list *)",
      "Bash(vault list *)",
      "Bash(vault policy *)",
      "Bash(wc *)",
      "Bash(yamllint *)",
      "Bash(yq *)",
      "Edit(//private/tmp/**)",
      "Edit(//tmp/**)",
      "Edit(//var/folders/*/*/T/**)",
      "Edit(~/.cache/**)",
      "Edit(~/.cargo/registry/**)",
      "Edit(~/.terraform.d/*cache*)",
      "Edit(~/.terraform.d/plugin-cache/**)",
      "Edit(~/conductor/workspaces/**)",
      "Edit(~/Library/Caches/pre-commit/**)",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "mcp__exa__get_code_context_exa",
      "mcp__exa__web_search_exa",
      "mcp__filesystem__*",
      "mcp__firecrawl-mcp__*",
      "mcp__grafana__*",
      "mcp__kubernetes-mcp-server__*",
      "mcp__notion__API-delete-a-block",
      "mcp__notion__API-get-block-children",
      "mcp__notion__API-get-self",
      "mcp__notion__API-patch-block-children",
      "mcp__notion__API-post-page",
      "mcp__notion__API-post-search",
      "mcp__notion__API-query-data-source",
      "mcp__notion__API-retrieve-a-data-source",
      "mcp__notion__API-update-a-block",
      "mcp__notion__notion-create-database",
      "mcp__notion__notion-create-pages",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-search",
      "mcp__notion__notion-update-database",
      "mcp__notion__notion-update-page",
      "mcp__terraform__*",
      "Read(~/.claude/plugins/cache/**)",
      "Read(~/.ssh/*.pub)",
      "Read(~/.ssh/known_hosts)",
      "Read(~/.terraform.d/**)",
      "Skill(commit-commands:clean_gone)",
      "Skill(commit-commands:commit-push-pr)",
      "Skill(commit-commands:commit)",
      "Skill(elements-of-style:improve-writing)",
      "Skill(elements-of-style:writing-clearly-and-concisely)",
      "Skill(homelab:grafana)",
      "Skill(pr-review-toolkit:review-pr)",
      "Skill(dev-flow:brainstorming)",
      "Skill(dev-flow:finishing-a-development-branch)",
      "Skill(dev-flow:requesting-code-review)",
      "Skill(dev-flow:subagent-driven-development)",
      "Skill(dev-flow:systematic-debugging)",
      "Skill(dev-flow:using-git-worktrees)",
      "Skill(dev-flow:writing-plans)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:api.notion.com)",
      "WebFetch(domain:app.terraform.io)",
      "WebFetch(domain:charts.helm.sh)",
      "WebFetch(domain:checkpoint-api.hashicorp.com)",
      "WebFetch(domain:cloud.google.com)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:developer.hashicorp.com)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:docs.aws.amazon.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:ghcr.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:k8s-cluster.fzymgc.house)",
      "WebFetch(domain:k8s.io)",
      "WebFetch(domain:kubernetes.io)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:objects.githubusercontent.com)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:quay.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:registry.terraform.io)",
      "WebFetch(domain:releases.hashicorp.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:tailscale.com)",
      "Bash(bd *)"
    ],
    "deny": [
      "WebFetch(domain:pastebin.com)",
      "Read(~/.ssh/id_*)",
      "Read(~/.ssh/*.pem)",
      "Read(~/.ssh/*.key)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(~/.aws/credentials)",
      "Read(~/.vault-token)",
      "Read(~/.netrc)",
      "Edit(~/.ssh/**)",
      "Edit(~/.gnupg/**)",
      "Bash(gh pr merge *)",
      "Bash(git merge *)",
      "Read(~/.kube/config)",
      "Read(~/.kube/configs/**)",
      "Read(~/.config/age-keys.txt)",
      "Read(~/.gnupg/**)"
    ],
    "ask": [
      "Bash(terraform destroy *)",
      "Bash(terraform apply *)",
      "Bash(kubectl delete *)",
      "Bash(rm -rf *)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": []
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": []
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "beads@beads-marketplace": true,
    "c4-architecture@claude-code-workflows": true,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "dev-flow@fzymgc-house-skills": true,
    "documentation-generation@claude-code-workflows": true,
    "double-shot-latte@superpowers-marketplace": false,
    "explanatory-output-style@claude-plugins-official": true,
    "jj@fzymgc-house-skills": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "engram@engram": true,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "fzymgc-house-skills": {
      "source": {
        "source": "github",
        "repo": "fzymgc-house/fzymgc-house-skills"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "engram": {
      "source": {
        "source": "github",
        "repo": "seanb4t/engram"
      },
      "autoUpdate": true
    },
    "weft": {
      "source": {
        "source": "directory",
        "path": "/Volumes/Code/github.com/seanb4t/weft-dogfood"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowUnixSockets": [
        "//run/user/*/gnupg/S.gpg-agent",
        "//run/user/*/gnupg/S.gpg-agent.ssh",
        "//tmp/com.apple.launchd.*/Listeners",
        "//private/tmp/com.apple.launchd.*/Listeners",
        "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock",
        "~/.1password/agent.sock"
      ],
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "docker",
      "kubectl",
      "terraform",
      "helm",
      "tf",
      "ssh",
      "scp",
      "rsync",
      "git",
      "uv",
      "bd"
    ]
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
